  "AVR Timer1": {
    "prefix": "avrtimer1",
    "body": [
      "noInterrupts();",
      "",
      "// Clear registers",
      "TCCR1A = 0;",
      "TCCR1B = 0;",
      "TCNT1 = 0;",
      "",
      "// Set compare match register (1 Hz)",
      "OCR1A = ${1:15624};",
      "",
      "// CTC mode",
      "TCCR1B |= (1 << WGM12);",
      "",
      "// Prescaler ${2:1024}",
      "TCCR1B |= (1 << CS12) | (1 << CS10);",
      "",
      "// Enable timer compare interrupt",
      "TIMSK1 |= (1 << OCIE1A);",
      "",
      "interrupts();",
      "${0}",
      "",
      "// Add ISR:",
      "// ISR(TIMER1_COMPA_vect) {",
      "//   // Timer interrupt code here",
      "// }"
    ],
    "description": "AVR Timer1 configuration with CTC mode"
  },
  "State Machine": {
    "prefix": "statemachine",
