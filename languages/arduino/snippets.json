  "Button Debounce": {
    "prefix": "debounce",
    "body": [
      "int reading = digitalRead(${1:buttonPin});",
      "",
      "if (reading != ${2:lastButtonState}) {",
      "\t${3:lastDebounceTime} = millis();",
      "}",
      "",
      "if ((millis() - ${3:lastDebounceTime}) > ${4:debounceDelay}) {",
      "\tif (reading != ${5:buttonState}) {",
      "\t\t${5:buttonState} = reading;",
      "\t\t",
      "\t\tif (${5:buttonState} == HIGH) {",
      "\t\t\t${6:// Button pressed action}",
      "\t\t}",
      "\t}",
      "}",
      "",
      "${2:lastButtonState} = reading;",
      "${0}"
    ],
    "description": "Button debouncing pattern"
  },
  "Moving Average Filter": {
    "prefix": "movingavg",
    "body": [
      "// Subtract the last reading",
      "${1:total} = ${1:total} - ${2:readings}[${3:readIndex}];",
      "",
      "// Read from the sensor",
      "${2:readings}[${3:readIndex}] = ${4:analogRead(A0)};",
      "",
      "// Add the reading to the total",
      "${1:total} = ${1:total} + ${2:readings}[${3:readIndex}];",
      "",
      "// Advance to the next position",
      "${3:readIndex} = (${3:readIndex} + 1) % ${5:numReadings};",
      "",
      "// Calculate the average",
      "${6:average} = ${1:total} / ${5:numReadings};",
      "${0}"
    ],
    "description": "Moving average filter for sensor smoothing"
  },
  "PID Controller": {
    "prefix": "pid",
    "body": [
      "double error = ${1:setpoint} - ${2:input};",
      "${3:errSum} += error;",
      "double dErr = error - ${4:lastErr};",
      "",
      "double ${5:output} = ${6:kp} * error + ${7:ki} * ${3:errSum} + ${8:kd} * dErr;",
      "",
      "${4:lastErr} = error;",
      "${0}"
    ],
    "description": "PID controller computation"
  },
  "I2C Master Write": {
    "prefix": "i2cwrite",
    "body": [
      "Wire.beginTransmission(${1:0x68}); // I2C address",
      "Wire.write(${2:0x00}); // Register address",
      "Wire.write(${3:data}); // Data to write",
      "Wire.endTransmission();",
      "${0}"
    ],
    "description": "I2C master write operation"
  },
  "I2C Master Read": {
    "prefix": "i2cread",
    "body": [
      "Wire.beginTransmission(${1:0x68}); // I2C address",
      "Wire.write(${2:0x00}); // Register address",
      "Wire.endTransmission(false);",
      "Wire.requestFrom(${1:0x68}, ${3:1}); // Request bytes",
