  "Median Filter": {
    "prefix": "median",
    "body": [
      "const int ${1:WINDOW_SIZE} = ${2:5};",
      "int ${3:readings}[${1:WINDOW_SIZE}];",
      "int ${4:sorted}[${1:WINDOW_SIZE}];",
      "",
      "// Add new reading and shift array",
      "for (int i = ${1:WINDOW_SIZE} - 1; i > 0; i--) {",
      "\t${3:readings}[i] = ${3:readings}[i - 1];",
      "}",
      "${3:readings}[0] = ${5:newReading};",
      "",
      "// Copy and sort",
      "memcpy(${4:sorted}, ${3:readings}, sizeof(${3:readings}));",
      "for (int i = 0; i < ${1:WINDOW_SIZE} - 1; i++) {",
      "\tfor (int j = i + 1; j < ${1:WINDOW_SIZE}; j++) {",
      "\t\tif (${4:sorted}[j] < ${4:sorted}[i]) {",
      "\t\t\tint temp = ${4:sorted}[i];",
      "\t\t\t${4:sorted}[i] = ${4:sorted}[j];",
      "\t\t\t${4:sorted}[j] = temp;",
      "\t\t}",
      "\t}",
      "}",
      "",
      "// Median is middle value",
      "int ${6:median} = ${4:sorted}[${1:WINDOW_SIZE} / 2];",
      "${0}"
    ],
    "description": "Median filter for noise reduction"
  },
