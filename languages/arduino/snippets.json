  "Blink Without Delay": {
    "prefix": "blink",
    "body": [
      "unsigned long previousMillis = 0;",
      "const long interval = ${1:1000};",
      "",
      "void loop() {",
      "\tunsigned long currentMillis = millis();",
      "\t",
      "\tif (currentMillis - previousMillis >= interval) {",
      "\t\tpreviousMillis = currentMillis;",
      "\t\t${2:// your code here}",
      "\t}",
      "}"
    ],
    "description": "Non-blocking blink pattern using millis()"
  },
